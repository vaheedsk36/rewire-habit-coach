# Dependencies
node_modules/
.pnp
.pnp.*

# Build output (any workspace)
.next/
out/
build/
dist/
*.tsbuildinfo
next-env.d.ts

# Environment — never commit real keys, but DO track the example
.env
.env.local
.env.*.local
!.env.example

# Testing / coverage
coverage/

# Logs
*-debug.log*
.pnpm-debug.log*

# Vercel
.vercel

# React Native (apps/mobile) — bare workflow: ios/ and android/ ARE committed.
# Build artifacts within them are ignored by apps/mobile/.gitignore.
*.orig.*
# Native release-signing material (debug.keystore stays committed)
*.jks
*.p8
*.p12
*.mobileprovision

# OS / editor
.DS_Store
*.pem
.idea/
.vscode/*
!.vscode/extensions.json
