# Rewire — environment variables
# Copy this file to .env.local and fill in values. .env.local is git-ignored.

# LLM provider — "google" (default, Gemini free tier) or "openai".
AI_PROVIDER=google

# Google Gemini (free tier) — get a key at https://aistudio.google.com/apikey
# SERVER-ONLY. Used exclusively inside services/ai. Never exposed to the browser.
GOOGLE_GENERATIVE_AI_API_KEY=your-gemini-key
# Optional: override the model (defaults to gemini-3-flash-preview).
# GOOGLE_MODEL=gemini-3-flash-preview

# OpenAI (fallback — used only when AI_PROVIDER=openai). SERVER-ONLY.
# OPENAI_API_KEY=sk-your-key-here
# OPENAI_MODEL=gpt-4o-mini

# Supabase — the URL and anon/publishable key are public (safe in the browser);
# Row-Level Security enforces per-user access on the server.
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-or-publishable-key

# Google OAuth — set to "true" ONLY after you have enabled the Google provider
# in Supabase (Authentication → Providers → Google) with a Google Cloud OAuth
# client. Until then, leave unset so the "Continue with Google" button stays
# hidden (a visible-but-unconfigured button would error).
# NEXT_PUBLIC_GOOGLE_OAUTH_ENABLED=true
