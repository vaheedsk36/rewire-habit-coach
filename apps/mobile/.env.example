# Mobile (bare React Native) env — inlined via react-native-dotenv at build time.
# NOT secrets: the Supabase anon key is public and RLS-guarded, and the API URL
# is the deployed web app. Never put the service-role or OpenAI key here.
# Copy to apps/mobile/.env and fill in.

SUPABASE_URL=https://YOUR-PROJECT.supabase.co
SUPABASE_ANON_KEY=your-anon-key
# Optional — defaults to the production web app if unset.
API_URL=https://rewire-habit-coach.vercel.app
