# Mobile (Expo) public env — inlined into the app bundle at build time.
# These are NOT secrets: the Supabase anon key is public and RLS-guarded, and
# the API URL is the deployed web app. Never put the service-role or OpenAI key here.
# Copy to apps/mobile/.env and fill in.

EXPO_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
# Optional — defaults to the production web app if unset.
EXPO_PUBLIC_API_URL=https://rewire-habit-coach.vercel.app
